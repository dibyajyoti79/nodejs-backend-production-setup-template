{
  "$schema": "https://json.schemastore.org/prettierrc",

  "semi": true,
  "trailingComma": "all",
  "singleQuote": false,
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "endOfLine": "lf",

  "plugins": ["@trivago/prettier-plugin-sort-imports"],

  "importOrder": ["^node:(.*)$", "^@/(.*)$", "^[./]"],

  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true
}
