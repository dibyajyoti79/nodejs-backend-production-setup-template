# ==================== Application Configuration ====================
# Environment: development, production, or test
NODE_ENV=development

# Server port (default: 3001)
PORT=4000


# ==================== Database Configuration ====================
# MongoDB connection string
# Local: mongodb://localhost:27017/urlshortener
# Docker: mongodb://mongo:27017/urlshortener
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/database
MONGO_URI=mongodb://localhost:27017/urlshortener

# ==================== Logging Configuration ====================
# Log level: error, warn, info, http, debug
# LOG_LEVEL=info

# ==================== Security Configuration ====================
# JWT secret for authentication (generate a strong secret for production)
# JWT_SECRET=your-super-secret-key-here

# CORS allowed origins (comma-separated for multiple origins)
# CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

